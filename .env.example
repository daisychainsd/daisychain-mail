# Beehiiv (https://app.beehiiv.com/settings/workspace/api)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Bandcamp (https://bandcamp.com/developer — OAuth token; seller band id from my_bands)
BANDCAMP_ACCESS_TOKEN=
BANDCAMP_BAND_ID=
# Optional: label sub-band filter
# BANDCAMP_MEMBER_BAND_ID=

# First run lower bound if KV empty (UTC "YYYY-MM-DD HH:mm:ss")
BANDCAMP_INITIAL_START_TIME=2000-01-01 00:00:00

# Vercel Cron + internal routes (generate strong random strings)
CRON_SECRET=
INTERNAL_SECRET=

# Laylo webhook: send header `x-webhook-secret: <value>` or `Authorization: Bearer <value>`
LAYLO_WEBHOOK_SECRET=

# Upstash Redis (Vercel Marketplace → Redis — cursor for Bandcamp incremental sync)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
