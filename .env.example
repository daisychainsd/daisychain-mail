# Beehiiv (https://app.beehiiv.com/settings/workspace/api)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Bandcamp — preferred: Client ID + Secret (app fetches tokens automatically; cache in Redis when UPSTASH_* set)
BANDCAMP_CLIENT_ID=
BANDCAMP_CLIENT_SECRET=
# Optional legacy: static Bearer token (expires ~1h); omit if using CLIENT_ID + SECRET above
# BANDCAMP_ACCESS_TOKEN=

# Numeric band/label id from https://bandcamp.com/developer/account (my_bands) — NOT the same as Client ID
BANDCAMP_BAND_ID=
# Optional: label sub-band filter
# BANDCAMP_MEMBER_BAND_ID=

BANDCAMP_INITIAL_START_TIME=2000-01-01 00:00:00

CRON_SECRET=
INTERNAL_SECRET=

LAYLO_WEBHOOK_SECRET=

# Shotgun API (Settings → Integrations → Shotgun APIs → Issue token)
SHOTGUN_API_TOKEN=
SHOTGUN_ORGANIZER_ID=216831
# ISO datetime cursor for first cron run; set to today after running backfill-shotgun.mjs
SHOTGUN_INITIAL_AFTER=

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
